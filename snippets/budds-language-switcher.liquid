{% if localization.available_languages.size > 1 %}
  <localization-form class="budds-language-switcher">
    {% form 'localization', id: 'BuddsLanguageForm', class: 'budds-language-switcher__form' %}
      <label class="budds-language-switcher__label" for="BuddsLanguageSelect">
        {{ 'sections.language_switcher.label' | t }}
      </label>

      <select
        id="BuddsLanguageSelect"
        class="budds-language-switcher__select"
        name="locale_code"
        aria-label="{{ 'sections.language_switcher.label' | t }}"
        onchange="this.form.submit()"
      >
        {% for language in localization.available_languages %}
          <option
            value="{{ language.iso_code }}"
            {% if language.iso_code == localization.language.iso_code %}
              selected
            {% endif %}
          >
            {{ language.endonym_name | capitalize }}
          </option>
        {% endfor %}
      </select>

      <button class="budds-language-switcher__button" type="submit">
        {{ 'sections.language_switcher.submit' | t }}
      </button>
    {% endform %}
  </localization-form>
{% endif %}

{% style %}
  .budds-language-switcher__form {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .budds-language-switcher__label {
    font-size: 14px;
    line-height: 1.2;
  }

  .budds-language-switcher__select,
  .budds-language-switcher__button {
    min-height: 40px;
    border: 1px solid currentColor;
    border-radius: 8px;
    background: #fff;
    color: inherit;
    font: inherit;
  }

  .budds-language-switcher__select {
    padding: 0 32px 0 12px;
  }

  .budds-language-switcher__button {
    padding: 0 14px;
    cursor: pointer;
  }

  .budds-language-switcher__select:focus-visible,
  .budds-language-switcher__button:focus-visible {
    outline: 3px solid currentColor;
    outline-offset: 3px;
  }

  @media screen and (max-width: 749px) {
    .budds-language-switcher__label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
{% endstyle %}
